# terraform.tfvars.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to terraform.tfvars and fill in non-secret values.
# NEVER commit terraform.tfvars to Git.
#
# Sensitive values (db_password, ror_secret_key_base, php_app_key,
# github_oauth_token) must be supplied via environment variables:
#
#   export TF_VAR_db_password="your-db-password"
#   export TF_VAR_ror_secret_key_base="$(rails secret)"
#   export TF_VAR_php_app_key="base64:..."
#   export TF_VAR_github_oauth_token="ghp_..."
#
# ─────────────────────────────────────────────────────────────────────────────

aws_region   = "ap-south-2"
environment  = "production"

# Networking
vpc_cidr             = "10.30.0.0/16"
public_subnet_cidrs  = ["10.30.1.0/24", "10.30.2.0/24"]
private_subnet_cidrs = ["10.30.3.0/24", "10.30.4.0/24"]
availability_zones   = ["ap-south-2a", "ap-south-2b"]

# Domains
domain_name   = "vichubro.online"
ror_subdomain = "movie.vichubro.online"
php_subdomain = "php.vichubro.online"

# EC2
key_pair_name         = "vishnu-terraform-key"
bastion_instance_type = "t3.micro"
ecs_instance_type     = "t3.medium"

# ECS sizing
ror_task_cpu    = 512
ror_task_memory = 1024
php_task_cpu    = 512
php_task_memory = 1024

ror_service_desired_count = 1
php_service_desired_count = 1

# RDS
db_instance_class = "db.t3.micro"
db_engine_version = "8.0"
ror_db_name       = "movie_review_production"
php_db_name       = "food_ordering_production"
db_username       = "admin"

# Rails
ror_rails_env = "production"

# Laravel
php_app_env = "production"

# Auto Scaling
asg_min_size         = 1
asg_max_size         = 3
asg_desired_capacity = 1

# GitHub
github_owner    = "VichuA2"
ror_github_repo = "movie-review-system"
php_github_repo = "food-ordering-system"
github_branch   = "main"

# S3
artifact_bucket_name = "vishnu-terraform-pipeline-artifacts"
